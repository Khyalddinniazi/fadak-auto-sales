# Copy this file to .env and fill in real values for production.
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-long-random-string

# Admin login credentials (the password is hashed in memory at startup).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Set to 1 only for local development. Leave as 0 (or unset) in production.
FLASK_DEBUG=0

# Port the app listens on (most hosts set this automatically).
PORT=5000
